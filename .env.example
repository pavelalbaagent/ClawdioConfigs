# OpenClaw v2 env template
# Copy required values into your runtime secret file (for example /etc/openclaw/openclaw.env).
# Keep this file committed with placeholders only.

# Core
OPENCLAW_ENV=production
OPENCLAW_TIMEZONE=America/Guayaquil
OPENCLAW_AUDIT_LOG=/var/log/openclaw/audit.log

# Telegram / command channel
TELEGRAM_BOT_TOKEN=<placeholder>
TELEGRAM_ALLOWED_CHAT_ID=<placeholder>

# Google OAuth (shared by Gmail / Drive / Calendar)
GOOGLE_CLIENT_ID=<placeholder>
GOOGLE_CLIENT_SECRET=<placeholder>
GOOGLE_REFRESH_TOKEN=<placeholder>
GMAIL_USER_EMAIL=<placeholder>
GOOGLE_DRIVE_ROOT_FOLDER_ID=<placeholder>
GOOGLE_CALENDAR_ID=<placeholder>

# Search / browsing (optional if using browser-only retrieval)
OPENCLAW_SEARCH_API_KEY=<placeholder>
BRAVE_SEARCH_API_KEY=<placeholder>
SERPAPI_API_KEY=<placeholder>

# GitHub
GITHUB_TOKEN=<placeholder>
GITHUB_OWNER=<placeholder>
GITHUB_REPO=<placeholder>

# LinkedIn (disabled by default, keep optional)
LINKEDIN_CLIENT_ID=<placeholder>
LINKEDIN_CLIENT_SECRET=<placeholder>
LINKEDIN_REDIRECT_URI=<placeholder>

# Personal task manager selector
PERSONAL_TASK_PROVIDER=todoist
TODOIST_API_TOKEN=<placeholder>

# Agent task manager selector
AGENT_TASK_PROVIDER=asana
ASANA_PERSONAL_ACCESS_TOKEN=<placeholder>
ASANA_WORKSPACE_GID=<placeholder>
LINEAR_API_KEY=<placeholder>
LINEAR_TEAM_ID=<placeholder>

# n8n
N8N_BASE_URL=<placeholder>
N8N_API_KEY=<placeholder>
N8N_WEBHOOK_SECRET=<placeholder>
N8N_DEFAULT_WORKFLOW_ID=<placeholder>

# Model providers
OPENAI_API_KEY=<placeholder>
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=<placeholder>
OPENROUTER_API_KEY=<placeholder>
OPENROUTER_FREE_MODEL=<placeholder_optional>
ANTHROPIC_API_KEY=<placeholder_optional>
MEMORY_SQLITE_DB_PATH=.memory/memory.db

# Gateway / app secrets
OPENCLAW_GATEWAY_TOKEN=<placeholder>
OPENCLAW_SIGNING_SECRET=<placeholder>

# Dashboard auth
OPENCLAW_DASHBOARD_TOKEN=<placeholder>

# Optional skill add-ons (config/addons.yaml)
SLACK_BOT_TOKEN=<placeholder_optional>
SLACK_SIGNING_SECRET=<placeholder_optional>
SLACK_APP_TOKEN=<placeholder_optional>
AGENTMAIL_API_KEY=<placeholder_optional>
TRELLO_API_KEY=<placeholder_optional>
TRELLO_TOKEN=<placeholder_optional>
TRELLO_DEFAULT_BOARD_ID=<placeholder_optional>
OP_SERVICE_ACCOUNT_TOKEN=<placeholder_optional>
OP_ACCOUNT=<placeholder_optional>
YTDLP_COOKIES_FILE=<placeholder_optional>
YTDLP_EXTRA_ARGS=<placeholder_optional>
TAVILY_API_KEY=<placeholder_optional>
CODEXBAR_API_KEY=<placeholder_optional>
